# AWS profile for CDK deployments (optional, uses default credentials if unset)
AWS_PROFILE=

# Sender domain — used by defineEmail() in test projects
TEST_SENDER_DOMAIN=test-mail.example.com
TEST_SENDER_HOSTED_ZONE_ID=Z0123456789ABCDEFGHIJ
TEST_SENDER_HOSTED_ZONE_DOMAIN=example.com

# Recipient domain — used by test-infra CDK stack (SES receipt rules + S3)
TEST_RECIPIENT_DOMAIN=test-recv.example.com
TEST_RECIPIENT_HOSTED_ZONE_ID=Z0123456789ABCDEFGHIJ
TEST_RECIPIENT_HOSTED_ZONE_DOMAIN=example.com
