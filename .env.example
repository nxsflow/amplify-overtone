# AWS profile for CDK deployments (optional, uses default credentials if unset)
AWS_PROFILE=

# npm Granular Access Token for publishing @nxsflow/* packages
# Generate at: https://www.npmjs.com/settings/<your-username>/tokens → "Granular Access Token"
#   Token name:          amplify-overtone-ci
#   Packages & scopes:   Read and write → Only select: @nxsflow
#   Organizations:       No access
#   Expiration:          90 days (maximum for write tokens)
# Used by `pnpm release:setup` to configure GitHub repo secrets and environment
NPM_TOKEN=

# Sender domain — used by email action integration tests (not by test-infra stack)
TEST_SENDER_DOMAIN=test-mail.example.com
TEST_SENDER_HOSTED_ZONE_ID=Z0123456789ABCDEFGHIJ
TEST_SENDER_HOSTED_ZONE_DOMAIN=example.com

# Recipient domain — used by test-infra stack (SES receipt rules, MX record, test user emails)
TEST_RECIPIENT_DOMAIN=test-recv.example.com
TEST_RECIPIENT_HOSTED_ZONE_ID=Z0123456789ABCDEFGHIJ
TEST_RECIPIENT_HOSTED_ZONE_DOMAIN=example.com
