{
    "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
    "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
    "files": {
        "ignoreUnknown": true,
        "includes": ["**", "!dist", "!node_modules", "!*.d.ts", "!.changeset", ".claude/**", "!.next", "!.source"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noUnknownAtRules": "error",
                "noThenProperty": "off"
            },
            "style": {
                "useImportType": "error",
                "noNonNullAssertion": "off"
            }
        }
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "trailingCommas": "all",
            "semicolons": "always"
        }
    }
}
