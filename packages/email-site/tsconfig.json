{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "jsx": "preserve",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "declaration": false,
        "declarationMap": false,
        "paths": {
            "@/*": ["./*"]
        },
        "plugins": [{ "name": "next" }]
    },
    "include": ["next-env.d.ts", "app/**/*.ts", "app/**/*.tsx", "amplify/**/*.ts"],
    "exclude": ["node_modules", ".next", ".amplify"]
}
